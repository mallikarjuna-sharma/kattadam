# Copy this file to .env.local and fill in your Supabase project values.
# Supabase Dashboard -> Project Settings -> API

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Optional (client-side auth if used later)
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# After setting env vars:
# 1. Run all SQL migrations in packages/data-layer/supabase/migrations/ (001 -> 005) in Supabase SQL Editor
# 2. Restart: npm run dev
# 3. Verify: npm run verify:supabase
